🔹  Calculate Total Sales
Sub TotalSales()

    Dim lastRow As Long
    lastRow = Cells(Rows.Count, 1).End(xlUp).Row
    
    Range("E1").Value = "Total"
    Range("E2").Value = Application.WorksheetFunction.Sum(Range("C2:C" & lastRow))

End Sub
🔹 Practice 8: Remove Duplicates
Sub RemoveDup()

    Dim lastRow As Long
    lastRow = Cells(Rows.Count, 1).End(xlUp).Row
    
    Range("A1:C" & lastRow).RemoveDuplicates Columns:=1, Header:=xlYes

End Sub
🔹 Practice 9: Sort Data
Sub SortSales()

    Range("A1:C5").Sort Key1:=Range("C2"), Order1:=xlDescending, Header:=xlYes

End Sub
